# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ------------------------------
# Dependencies
# ------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ------------------------------
# Build output
# ------------------------------
/.next/
/out/
/build
/dist
*.tsbuildinfo

# ------------------------------
# Testing / coverage
# ------------------------------
/coverage

# ------------------------------
# Next.js generated
# ------------------------------
next-env.d.ts

# ------------------------------
# Environment variables (NEVER commit real values — use .env.example)
# ------------------------------
.env
.env.local
.env.*.local
!.env.example

# ------------------------------
# Debug logs
# ------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ------------------------------
# Deployment platforms
# ------------------------------
.vercel

# ------------------------------
# OS / editor artifacts
# ------------------------------
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# ------------------------------
# InsForge & AI agent skills (installed locally per project)
# ------------------------------
.insforge
.agent
.agents
.augment
.claude
.cline
.kilocode
.qoder
.qwen
.roo
.trae
.windsurf
.github/copilot*
skills-lock.json

# ------------------------------
# Temp scaffolding artifacts (Windows fs lock — remove manually once released)
# ------------------------------
scaffold-tmp/
.gitignore.insforge
.gitignore.nextjs
