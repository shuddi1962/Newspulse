# ============================================================================
# NewsPulse PRO — Environment variables
# ============================================================================
# Copy this file to `.env.local` and fill in real values. Never commit .env.local.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# ============================================================================

# ----- Site -----
# Public base URL used by metadata, OG tags, sitemap, canonicals.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Brand/name used in titles and UI chrome.
NEXT_PUBLIC_SITE_NAME=NewsPulse PRO

# ----- InsForge (backend — see .insforge/project.json) -----
# OSS host URL for the linked project (mirrors `oss_host`).
NEXT_PUBLIC_INSFORGE_URL=
# Anonymous JWT used by browser clients (RLS enforces authorization).
# Retrieve via: `npx @insforge/cli secrets get ANON_KEY`.
NEXT_PUBLIC_INSFORGE_ANON_KEY=
# Service role key — SERVER-ONLY. Never expose to the browser.
INSFORGE_SERVICE_KEY=
# Direct API key used by the InsForge CLI (already in .insforge/project.json).
INSFORGE_API_KEY=

# ----- Payments -----
# Stripe (global)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Paystack (Africa)
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
# Flutterwave (Africa)
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_HASH=
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=
# NowPayments (crypto)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# ----- Email (transactional + newsletter) -----
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=no-reply@newspulse.example
EMAIL_FROM_NAME=NewsPulse PRO

# ----- AI providers (augment InsForge AI Gateway where needed) -----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ----- Maps -----
# Mapbox public token — used by directory + real-estate map views.
NEXT_PUBLIC_MAPBOX_TOKEN=

# ----- Analytics / monitoring -----
NEXT_PUBLIC_GA_ID=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ----- Image hosts (allowed domains for next/image) -----
# Comma-separated list. Populated automatically from InsForge storage CDN.
NEXT_PUBLIC_IMAGE_HOSTS=

# ----- Security -----
# Random 32-byte secret used for server-side session signing. Generate with:
#   openssl rand -base64 32
SESSION_SECRET=
# Comma-separated list of IPs allowed to hit the admin-only API routes (optional).
ADMIN_IP_ALLOWLIST=
